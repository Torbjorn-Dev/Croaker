config/icon="res://icon.svg"

[autoload]

Music="*res://Prefabs/Music.tscn"
GameStateManager="*res://Scripts/GameStateManager.cs"
GameManager="*res://Prefabs/GameManager.tscn"

[display]

window/size/mode=3
window/stretch/mode="viewport"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="Toad Queller"

[editor]

movie_writer/disable_vsync=true

